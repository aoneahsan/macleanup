{
  "name": "macleanup",
  "version": "4.4.1",
  "description": "Comprehensive, safe-by-default macOS cleanup & maintenance tool — 27 sections, dry-run support, zero install via npx.",
  "bin": {
    "macleanup": "bin/mac-cleanup.js",
    "mac-cleanup": "bin/mac-cleanup.js"
  },
  "main": "bin/mac-cleanup.js",
  "files": [
    "bin/",
    "mac-cleanup.sh",
    "README.md",
    "LICENSE.md",
    "NOTICE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "start": "node bin/mac-cleanup.js",
    "list": "node bin/mac-cleanup.js --list",
    "version:print": "node bin/mac-cleanup.js --version",
    "dry-run": "node bin/mac-cleanup.js --dry-run --all",
    "lint:bash": "bash -n mac-cleanup.sh && node -c bin/mac-cleanup.js",
    "prepublishOnly": "bash -n mac-cleanup.sh && node -c bin/mac-cleanup.js && test -x mac-cleanup.sh && test -x bin/mac-cleanup.js"
  },
  "preferGlobal": true,
  "engines": {
    "node": ">=14"
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "keywords": [
    "macos",
    "mac",
    "cleanup",
    "maintenance",
    "disk-space",
    "cache",
    "uninstall",
    "developer-tools",
    "node_modules",
    "xcode",
    "homebrew",
    "docker",
    "system-cleanup",
    "macos-tools",
    "cli",
    "bash",
    "interactive",
    "dry-run",
    "launchagents",
    "stale-builds",
    "sysadmin"
  ],
  "author": {
    "name": "Ahsan Mahmood",
    "email": "aoneahsan@gmail.com",
    "url": "https://aoneahsan.com"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aoneahsan/macleanup.git"
  },
  "bugs": {
    "url": "https://github.com/aoneahsan/macleanup/issues",
    "email": "aoneahsan@gmail.com"
  },
  "homepage": "https://github.com/aoneahsan/macleanup#readme",
  "publishConfig": {
    "access": "public"
  },
  "funding": {
    "type": "individual",
    "url": "https://aoneahsan.com"
  }
}
