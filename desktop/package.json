{
  "name": "macleanup-desktop",
  "private": true,
  "version": "4.6.1",
  "type": "module",
  "description": "macleanup — native macOS GUI (Tauri) in front of the mac-cleanup CLI.",
  "license": "MIT",
  "scripts": {
    "sync:script": "node scripts/sync-script.mjs",
    "gen:icons": "node scripts/gen-icons.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run sync:script && tauri dev",
    "tauri:build": "npm run sync:script && npm run gen:icons && tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@tauri-apps/plugin-process": "^2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
