rules_version = '2';

// macleanup — Firestore security rules.
// Each authenticated user may read/write ONLY their own users/{uid} document
// (used for sign-in records + run counts). Nothing else is accessible. Deploy
// with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Allow create/update of one's own doc. Keep it to known fields and
      // never let a client write an arbitrary "plan"/entitlement they grant
      // themselves — those should be set by your backend/admin only.
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['email', 'displayName', 'runs', 'lastRunAt']);

      allow delete: if false;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
